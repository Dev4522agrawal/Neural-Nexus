# Copy to .env. FREE SETUP: you only need GEMINI_API_KEY —
# get one free (no credit card) at https://aistudio.google.com -> "Get API key".

# --- Databases ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neuralnexus
DATABASE_URL=postgresql+asyncpg://nexus:neuralnexus@localhost:5432/nexus
POSTGRES_PASSWORD=neuralnexus

# --- Graph engine provider ---
# gemini = Google free tier (daily quota) | ollama = fully local, unlimited
# hybrid = ollama first, Gemini rescues failed extractions (recommended for bulk
#          imports; embeddings always stay local) | openai = paid
GRAPH_PROVIDER=hybrid

# --- Keys (only the one matching your provider is needed) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Free-tier rate limits are low; this caps Graphiti's parallel LLM calls so
# ingestion slows down instead of erroring. Raise it if you ever pay.
SEMAPHORE_LIMIT=2

# --- AI Router (LiteLLM model strings; defaults are all free-tier Gemini) ---
# MODEL_CODE=gemini/gemini-2.5-flash
MODEL_RESEARCH=gemini/gemini-2.5-pro   # hard questions get the smart model's small free allowance
# MODEL_GENERAL=gemini/gemini-2.5-flash
# MODEL_OFFLINE=ollama/llama3.1:8b
